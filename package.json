{
  "name": "@unoff/cli",
  "version": "0.1.3",
  "description": "A CLI tool to create plugins for Figma, Penpot, Sketch, and Framer",
  "main": "dist/index.js",
  "type": "module",
  "bin": {
    "unoff": "./bin/unoff.js"
  },
  "files": [
    "bin/",
    "dist/",
    "templates/"
  ],
  "scripts": {
    "build": "tsc",
    "dev": "tsc --watch",
    "prepare": "(git submodule update --init --recursive || true) && npm run build",
    "test": "vitest run",
    "test:watch": "vitest",
    "format": "npx prettier --write ."
  },
  "keywords": [
    "figma",
    "penpot",
    "sketch",
    "framer",
    "plugin",
    "cli",
    "generator",
    "create-plugin"
  ],
  "author": "",
  "license": "MPL-2.0",
  "dependencies": {
    "chalk": "^5.3.0",
    "commander": "^11.1.0",
    "fs-extra": "^11.2.0",
    "inquirer": "^9.2.12",
    "mustache": "^4.2.0",
    "ora": "^8.0.1"
  },
  "devDependencies": {
    "@types/fs-extra": "^11.0.4",
    "@types/inquirer": "^9.0.9",
    "@types/mustache": "^4.2.5",
    "@types/node": "^20.10.5",
    "prettier": "^3.2.5",
    "typescript": "^5.3.3",
    "vitest": "^4.0.18"
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/yelbolt/unoff-cli.git"
  }
}
